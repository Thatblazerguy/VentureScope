# OpenClaw Global Environment Template
# Copy this to .env in backend/ and openclaw/ directories

# --- AI CONFIGURATION ---
# Your Google Gemini API Key from https://aistudio.google.com/
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash

# --- SUPABASE CONFIGURATION ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_OPPORTUNITIES_TABLE=opportunities

# --- SERVER CONFIGURATION ---
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# --- OPENCLAW CONFIGURATION ---
OPENCLAW_COPILOT_URL=http://localhost:4000
